# WayForPay credentials (from cabinet.wayforpay.com)
# Testing: use test_merch_n1 / flk3409refn54t54t*FNJRET
WAYFORPAY_MERCHANT_ACCOUNT=
WAYFORPAY_MERCHANT_SECRET_KEY=
WAYFORPAY_MERCHANT_DOMAIN=

# Resend (resend.com)
# Testing: use onboarding@resend.dev as RESEND_FROM_EMAIL
# Production: verify your domain in Resend dashboard first
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Google Sheets
# Sheet ID from the URL: docs.google.com/spreadsheets/d/SHEET_ID/edit
GOOGLE_SHEET_ID=
# Service account credentials JSON — paste as a single-line string wrapped in single quotes
# '{"type":"service_account","project_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...","client_email":"...@....iam.gserviceaccount.com",...}'
GOOGLE_CREDENTIALS=

# Admin scanner password (used on /admin route in the browser)
VITE_ADMIN_PASSWORD=
